{
  "version": 8,
  "name": "秋季南疆环线攻略",
  "metadata": {
    "mapbox:autocomposite": true
  },
  "sources": {
    "background": {
      "type": "vector",
      "url": "mapbox://vector/mapbox.mapbox-streets-v8"
    }
  },
  "layers": [
    {
      "id": "background-fill",
      "type": "background",
      "paint": {
        "background-color": "#f9e7d0"
      }
    },
    {
      "id": "route-main",
      "type": "line",
      "source": "background",
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#000000",
        "line-width": 4,
        "line-opacity": 0.9
      },
      "filter": [
        "==",
        "$type",
        "LineString"
      ]
    },
    {
      "id": "route-desert-highway",
      "type": "line",
      "source": "background",
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d32f2f",
        "line-width": 4,
        "line-opacity": 0.95,
        "line-dasharray": [
          4,
          2
        ]
      },
      "filter": [
        "==",
        "$type",
        "LineString"
      ]
    },
    {
      "id": "poi-icon",
      "type": "symbol",
      "source": "background",
      "layout": {
        "icon-image": "poi-marker-15",
        "icon-size": 0.8,
        "icon-allow-overlap": true,
        "icon-ignore-placement": true
      },
      "paint": {
        "icon-color": "#ffffff",
        "icon-halo-color": "#000000",
        "icon-halo-width": 1
      },
      "filter": [
        "==",
        "class",
        "poi"
      ]
    },
    {
      "id": "annotation-label",
      "type": "symbol",
      "source": "background",
      "layout": {
        "text-field": "{name}",
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 14,
        "text-anchor": "top",
        "text-offset": [
          0,
          1.2
        ]
      },
      "paint": {
        "text-color": "#2c2c2c",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      },
      "filter": [
        "has",
        "name"
      ]
    },
    {
      "id": "info-card-bg",
      "type": "fill",
      "source": "background",
      "paint": {
        "fill-color": "#f9e7d0",
        "fill-opacity": 0.95
      },
      "filter": [
        "==",
        "layer",
        "info-card"
      ]
    },
    {
      "id": "info-card-border",
      "type": "line",
      "source": "background",
      "paint": {
        "line-color": "#d4af37",
        "line-width": 2
      },
      "filter": [
        "==",
        "layer",
        "info-card-border"
      ]
    },
    {
      "id": "info-card-title",
      "type": "symbol",
      "source": "background",
      "layout": {
        "text-field": "{title}",
        "text-font": [
          "Noto Sans Bold"
        ],
        "text-size": 16,
        "text-max-width": 12,
        "text-line-height": 1.3
      },
      "paint": {
        "text-color": "#2c2c2c",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      },
      "filter": [
        "==",
        "layer",
        "info-card-title"
      ]
    },
    {
      "id": "info-card-body",
      "type": "symbol",
      "source": "background",
      "layout": {
        "text-field": "{body}",
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 12,
        "text-max-width": 14,
        "text-line-height": 1.4
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 0.5
      },
      "filter": [
        "==",
        "layer",
        "info-card-body"
      ]
    },
    {
      "id": "connector-arrow",
      "type": "line",
      "source": "background",
      "layout": {
        "line-cap": "butt",
        "line-join": "bevel"
      },
      "paint": {
        "line-color": "#d32f2f",
        "line-width": 2,
        "line-opacity": 0.9
      },
      "filter": [
        "==",
        "layer",
        "connector"
      ]
    },
    {
      "id": "connector-arrow-tip",
      "type": "symbol",
      "source": "background",
      "layout": {
        "icon-image": "arrow-tip-12",
        "icon-size": 0.6,
        "icon-rotate": [
          "get",
          "angle"
        ],
        "icon-allow-overlap": true,
        "icon-ignore-placement": true
      },
      "paint": {
        "icon-color": "#d32f2f"
      },
      "filter": [
        "==",
        "layer",
        "connector-tip"
      ]
    }
  ],
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "sprite": "mapbox://sprites/mapbox/streets-v11",
  "transition": {
    "duration": 300
  }
}