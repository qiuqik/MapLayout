{
  "version": 8,
  "name": "秋季南疆环线攻略",
  "metadata": {
    "mapbox:studio:owner": "user",
    "mapbox:studio:project": "autumn_southern_xinjiang"
  },
  "sources": {
    "background": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": [
          {
            "type": "Feature",
            "geometry": {
              "type": "Polygon",
              "coordinates": [
                [
                  [
                    0,
                    0
                  ],
                  [
                    1000,
                    0
                  ],
                  [
                    1000,
                    1000
                  ],
                  [
                    0,
                    1000
                  ],
                  [
                    0,
                    0
                  ]
                ]
              ]
            },
            "properties": {}
          }
        ]
      }
    }
  },
  "layers": [
    {
      "id": "background-fill",
      "type": "fill",
      "source": "background",
      "paint": {
        "fill-color": "#f9e4c3",
        "fill-opacity": 1.0
      }
    },
    {
      "id": "route-main",
      "type": "line",
      "source": "background",
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#000000",
        "line-width": 4,
        "line-opacity": 0.9
      },
      "filter": [
        "==",
        "$type",
        "LineString"
      ]
    },
    {
      "id": "route-descent",
      "type": "line",
      "source": "background",
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d62728",
        "line-width": 3,
        "line-opacity": 0.95
      },
      "filter": [
        "==",
        "$type",
        "LineString"
      ]
    },
    {
      "id": "poi-icon",
      "type": "symbol",
      "source": "background",
      "layout": {
        "icon-image": "location-pin-15",
        "icon-size": 0.8,
        "icon-allow-overlap": true,
        "text-field": "{name}",
        "text-font": [
          "Open Sans Bold",
          "Arial Unicode MS Bold"
        ],
        "text-size": 12,
        "text-offset": [
          0,
          1.2
        ],
        "text-anchor": "top",
        "text-allow-overlap": true
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      },
      "filter": [
        "has",
        "name"
      ]
    },
    {
      "id": "annotation-card-bg",
      "type": "fill",
      "source": "background",
      "paint": {
        "fill-color": "#f8e9c5",
        "fill-opacity": 0.95,
        "fill-outline-color": "#d4b57a"
      },
      "filter": [
        "==",
        "type",
        "card-bg"
      ]
    },
    {
      "id": "annotation-card-border",
      "type": "line",
      "source": "background",
      "paint": {
        "line-color": "#d4b57a",
        "line-width": 1.5
      },
      "filter": [
        "==",
        "type",
        "card-border"
      ]
    },
    {
      "id": "annotation-title",
      "type": "symbol",
      "source": "background",
      "layout": {
        "text-field": "{title}",
        "text-font": [
          "Noto Sans CJK SC Bold",
          "Microsoft YaHei Bold"
        ],
        "text-size": 14,
        "text-max-width": 12,
        "text-line-height": 1.2,
        "text-letter-spacing": -0.02,
        "text-justify": "left"
      },
      "paint": {
        "text-color": "#2e7d32",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      },
      "filter": [
        "==",
        "type",
        "card-title"
      ]
    },
    {
      "id": "annotation-body",
      "type": "symbol",
      "source": "background",
      "layout": {
        "text-field": "{body}",
        "text-font": [
          "Noto Sans CJK SC Regular",
          "Microsoft YaHei Regular"
        ],
        "text-size": 12,
        "text-max-width": 14,
        "text-line-height": 1.4,
        "text-justify": "left"
      },
      "paint": {
        "text-color": "#5d4037",
        "text-halo-color": "#ffffff",
        "text-halo-width": 0.8
      },
      "filter": [
        "==",
        "type",
        "card-body"
      ]
    },
    {
      "id": "connector-arrow",
      "type": "line",
      "source": "background",
      "layout": {
        "line-cap": "butt",
        "line-join": "bevel"
      },
      "paint": {
        "line-color": "#d62728",
        "line-width": 2,
        "line-opacity": 0.9
      },
      "filter": [
        "==",
        "type",
        "connector"
      ]
    },
    {
      "id": "arrowhead",
      "type": "symbol",
      "source": "background",
      "layout": {
        "icon-image": "arrowhead-12",
        "icon-size": 0.6,
        "icon-rotate": "{angle}",
        "icon-anchor": "bottom",
        "icon-offset": [
          0,
          3
        ],
        "icon-allow-overlap": true
      },
      "paint": {
        "icon-color": "#d62728"
      },
      "filter": [
        "==",
        "type",
        "arrowhead"
      ]
    }
  ],
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "sprite": "mapbox://sprites/mapbox/streets-v11",
  "transition": {
    "duration": 300,
    "delay": 0
  }
}